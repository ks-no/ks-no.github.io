{
  "openapi": "3.0.3",
  "info": {
    "title": "KS FIKS: Konsesjon folkeregister konfigurasjon API",
    "description": "API for konfigurasjon av folkeregister-integrasjon for Konsesjon-tjenesten.",
    "contact": {
      "name": "Fiks konsesjon",
      "url": "https://www.ks.no/fagomrader/digitalisering/utviklingsprosjekter",
      "email": "fiks-utvikling@ksdigital.no"
    },
    "version": "v1"
  },
  "servers": [
    {
      "url": "https://api.fiks.ks.no",
      "description": "KS Fiks API host"
    },
    {
      "url": "https://api.test.fiks.ks.no",
      "description": "KS Fiks TEST API host"
    }
  ],
  "tags": [
    {
      "name": "FolkeregisterKonfigurasjon",
      "description": "Konfigurasjon av folkeregister-integrasjon for Konsesjon"
    }
  ],
  "paths": {
    "/konsesjon-api/v1/konfigurasjon/{fiksOrgId}/folkeregister": {
      "post": {
        "tags": [
          "FolkeregisterKonfigurasjon"
        ],
        "summary": "Konfigurer folkeregister-integrasjon",
        "description": "Setter opp folkeregister-integrasjon for kommunen.",
        "operationId": "konfigurerFolkeregister",
        "parameters": [
          {
            "in": "path",
            "name": "fiksOrgId",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/FiksOrgId"
            },
            "description": "Fiks organisasjons-ID for kommunen"
          }
        ],
        "responses": {
          "204": {
            "description": "Konfigurasjon fullført"
          },
          "400": {
            "description": "Feil input",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://developers.fiks.ks.no/api/fiks-common.json#/components/schemas/ErrorMessage"
                }
              }
            }
          },
          "401": {
            "description": "Ikke tilgang – bearer token ikke sendt",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://developers.fiks.ks.no/api/fiks-common.json#/components/schemas/ErrorMessage"
                }
              }
            }
          },
          "403": {
            "description": "Ikke tilgang",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://developers.fiks.ks.no/api/fiks-common.json#/components/schemas/ErrorMessage"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "FiksOrgId": {
        "type": "string",
        "format": "uuid",
        "description": "Fiks organisasjons-ID (UUID)"
      }
    }
  }
}

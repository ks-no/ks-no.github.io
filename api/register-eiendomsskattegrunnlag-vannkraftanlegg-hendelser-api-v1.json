  "paths": {
    "/register/api/v1/ks/{rolleId}/eiendomsskattegrunnlag/vannkraftanlegg/endring": {
      "get": {
        "tags": ["EiendomsskattegrunnlagVannkraftanlegg"],
        "description": "",
        "operationId": "hentEndring",
        "parameters": [
          {
            "name": "rolleId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EndringerEiendomsskattegrunnlagVannkraftanlegg"
                }
              }
            }
          }
        }
      }
    },
    "/register/api/v1/ks/{rolleId}/eiendomsskattegrunnlag/vannkraftanlegg/oversikter": {
      "get": {
        "tags": ["EiendomsskattegrunnlagVannkraftanlegg"],
        "description": "Oversikt eiendomsskattegrunnlag for vannkraftanlegg",
        "operationId": "hentOversikter",
        "parameters": [
          {
            "name": "rolleId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/OversiktEiendomsskattVannkraftanlegg"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "OversiktEiendomsskattVannkraftanlegg": {
        "required": ["eier", "kraftverk", "eiendomsskattegrunnlag","oversiktId"],
        "type": "object",
        "properties": {
          "eier": {
            "$ref": "#/components/schemas/Eier"
          },
          "kraftverk": {
            "$ref": "#/components/schemas/Kraftverk"
          },
          "eiendomsskattegrunnlag": {
            "$ref": "#/components/schemas/Eiendomsskattegrunnlag"
          },
          "oversiktId": {
            "type": "string",
            "format": "uuid",
            "description": "Identifikator for hvert enkelt oversiktsbilde"
          },
          "hentetAvRolle": {
            "type": "string"
          },
          "varslingAktivert": {
            "type": "boolean"
          },
          "status": {
            "type": "string",
            "enum": [
              "OK",
              "UNDER_BEHANDING",
              "FEILET"
            ],
            "description": "Status for?"
          }
        }
      },
      "Eier": {
        "type": "object",
        "properties": {
          "organisasjonsnummer": {
            "pattern": "^[0-9]{9}$",
            "type": "string"
          },
          "personidentifikator": {
            "pattern": "^[0-9]{11}$",
            "type": "string"
          },
          "navn": {
            "type": "string"
          }
        }
      },
      "Kraftverk": {
        "type": "object",
        "required": ["kraftverknavn", "kraftverknummer"],
        "properties": {
          "kraftverknummer": {
            "type": "string"
          },
          "kraftverknavn": {
            "type": "string"
          }
        }
      },
      "Eiendomsskattegrunnlag": {
        "type": "object",
        "required": ["inntektsaar", "gjelderPeriode", "samletEiendomsskattegrunnlag", "fordeltEiendomsskattegrunnlag", "fordelingsnoekkel"],
        "properties": {
          "inntektsaar": {
            "type": "integer"
          },
          "gjelderPeriode": {
            "type": "integer"
          },
          "samletEiendomsskattegrunnlag": {
            "type": "string",
            "format": "decimal"
          },
          "fordeltEiendomsskattegrunnlag": {
            "type": "string"
          },
          "fordelingsnoekkel": {
            "type": "string"
          }
        }
      },
      "EndringerEiendomsskattegrunnlagVannkraftanlegg": {
        "type": "object",
        "required": ["sekvensnummerForHendelse", "eier", "hendelsestype", "opprettelsestidspunkt", "gjelderPeriode", "fiksEndringstype"],
        "properties": {
          "sekvensnummerForHendelse": {
            "type": "number"
          },
          "eier": {
            "$ref": "#/components/schemas/Eier"
          },
          "hendelsestype": {
            "type": "string",
            "enum": [
              "NY",
              "SLETTET",
              "ENDRET"
            ]
          },
          "opprettelsestidspunkt": {
            "type": "string"
          },
          "gjelderPeriode": {
            "type": "string"
          },
          "fiksEndringstype": {
            "type": "string",
            "enum": [
              "ENDRING_EIERFORHOLD",
              "ENDRING_FORDELT_EIENDOMSSKATTEGRUNNLAG",
              "NYTT_KRAFTANLEGG",
              "AVSLUTTET_KRAFTANLEGG"
            ]
          }
        }
      }
    }
  }
}


{
  "openapi": "3.1.1",
  "info": {
    "title": "KS Fiks: Tilskuddsregister v1",
    "description": "Service for Tilskuddregister",
    "contact": {
      "name": "Fiks-brukerstøtte",
      "url": "https://ks-no.github.io/",
      "email": "fiks-utvikling@ks.no"
    },
    "version": "v1"
  },
  "servers": [
    {
      "url": "https://api.fiks.ks.no",
      "description": "KS Fiks API host"
    },
    {
      "url": "https://api.fiks.test.ks.no",
      "description": "KS Fiks TEST API host",
      "variables": {}
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "RegisterOppslag",
      "description": "Åpne endepunkter for å slå opp i tilskuddsregisteret"
    },
    {
      "name": "RegisterEndring",
      "description": "Endepunkter for å gjøre endringer i tilskuddsregisteret"
    }
  ],
  "paths": {
    "/tilskuddsregister/api/v1/oppslag/ordning": {
      "get": {
        "tags": [
          "RegisterOppslag"
        ],
        "operationId": "soekEtterTilskuddsordning",
        "summary": "Lister ut tilgjengelig tilskuddsordninger",
        "parameters": [
          {
            "name": "sidenummer",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "ordningerPrSide",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "sok",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SokEtterOrdningResponse"
                }
              }
            }
          },
          "default": {
            "description": "Noe gikk galt",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          }
        }
      }
    },
    "/tilskuddsregister/api/v1/oppslag/ordning/{id}": {
      "get": {
        "tags": [
          "RegisterOppslag"
        ],
        "operationId": "hentTilskuddsordning",
        "summary": "Henter ut en tilskuddsordning med id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "TilskuddsId",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrdningDetaljer"
                }
              }
            }
          },
          "404": {
            "description": "Tilskuddsordningen ikke funnet",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          }
        }
      }
    },
    "/tilskuddsregister/api/v1/endring/ordning": {
      "post": {
        "tags": [
          "RegisterEndring"
        ],
        "operationId": "registrerTilskuddsordning",
        "summary": "Registrer en tilskuddsordning i tilskuddsregisteret",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegistrerOrdningRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Tilskuddsordningen er registrert",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrdningId"
                }
              }
            }
          },
          "403": {
            "description": "Ikke tilgang",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          },
          "default": {
            "description": "Noe gikk galt",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          }
        }
      }
    },
    "/tilskuddsregister/api/v1/endring/ordning/{id}": {
      "put": {
        "tags": [
          "RegisterEndring"
        ],
        "operationId": "overskrivTilskuddsordning",
        "summary": "Overskriver alle data for en eksisterende tilskuddsordning i tilskuddsregisteret",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "TilskuddsId",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegistrerOrdningRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Tilskuddsordingen er endret",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrdningId"
                }
              }
            }
          },
          "403": {
            "description": "Ikke tilgang",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          },
          "404": {
            "description": "Tilskuddsordningen ikke funnet",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          },
          "default": {
            "description": "Noe gikk galt",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "RegisterEndring"
        ],
        "operationId": "slettTilskuddsordning",
        "summary": "Sletter en tilskuddsordning. (Soft delete: Setter status til slettet, men informasjon om ordningen vil fortsatt ligge i databasen)",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "TilskuddsId",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tilskuddsordningen er slettet",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrdningId"
                }
              }
            }
          },
          "403": {
            "description": "Ikke tilgang",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          },
          "404": {
            "description": "Tilskuddsordningen ikke funnet",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          },
          "default": {
            "description": "Noe gikk galt",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "OrdningId": {
        "type": "object",
        "properties": {
          "tilskuddsordningId": {
            "type": "string",
            "format": "uuid",
            "readOnly": true
          },
          "ordningId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9-]+$",
            "example": "TO-100001",
            "readOnly": true
          }
        }
      },
      "OrdningStatus": {
        "type": "string",
        "enum": [
          "KLADD",
          "REGISTRERT",
          "SLETTET"
        ],
        "example": "REGISTRERT"
      },
      "OrdningBase": {
        "type": "object",
        "properties": {
          "tittel": {
            "type": "array",
            "maxItems": 6,
            "items": {
              "$ref": "#/components/schemas/Tekst"
            }
          },
          "kortBeskrivelse": {
            "type": "array",
            "maxItems": 6,
            "items": {
              "$ref": "#/components/schemas/Tekst"
            }
          },
          "status": {
            "$ref": "#/components/schemas/OrdningStatus"
          },
          "stoerrelseMottaker": {
            "type": "array",
            "maxItems": 5,
            "items": {
              "type": "string"
            }
          },
          "naering": {
            "type": "array",
            "maxItems": 5,
            "items": {
              "type": "string"
            }
          },
          "regionsnivaa": {
            "$ref": "#/components/schemas/Regionsnivaa"
          },
          "region": {
            "type": "array",
            "maxItems": 10,
            "items": {
              "type": "string"
            }
          },
          "soknadsfrist": {
            "$ref": "#/components/schemas/Soknadsfrist"
          },
          "rolle": {
            "type": "array",
            "maxItems": 5,
            "items": {
              "$ref": "#/components/schemas/Rolle"
            }
          }
        }
      },
      "OrdningUtvidet": {
        "type": "object",
        "properties": {
          "stoettetiltaksnummer": {
            "type": "string",
            "description": "Id for støtteordning i Støtteregisteret"
          },
          "skjemaUrl": {
            "type": "string",
            "format": "uri"
          },
          "kontaktperson": {
            "$ref": "#/components/schemas/Kontaktperson"
          },
          "maalOgMaalgruppe": {
            "type": "array",
            "maxItems": 6,
            "items": {
              "$ref": "#/components/schemas/Tekst"
            }
          },
          "hvemKanMotta": {
            "type": "array",
            "maxItems": 6,
            "items": {
              "$ref": "#/components/schemas/Tekst"
            }
          },
          "bruksomraade": {
            "type": "array",
            "maxItems": 6,
            "items": {
              "$ref": "#/components/schemas/Tekst"
            }
          },
          "andreTildeingskriterier": {
            "type": "array",
            "maxItems": 6,
            "items": {
              "$ref": "#/components/schemas/Tekst"
            }
          },
          "rapporteringskrav": {
            "type": "array",
            "maxItems": 6,
            "items": {
              "$ref": "#/components/schemas/Tekst"
            }
          },
          "infoOmSokeprosessen": {
            "type": "array",
            "maxItems": 6,
            "items": {
              "$ref": "#/components/schemas/Tekst"
            }
          }
        }
      },
      "OrdningDetaljer": {
        "type": "object",
        "readOnly": true,
        "required": [
          "tilskuddsordningId",
          "ordningId",
          "opprettet",
          "endret",
          "tittel",
          "kortBeskrivelse",
          "status",
          "stoerrelseMottaker",
          "naering",
          "regionsnivaa",
          "region",
          "soknadsfrist",
          "rolle",
          "kontaktperson"
        ],
        "allOf": [
          {
            "$ref": "#/components/schemas/OrdningId"
          },
          {
            "$ref": "#/components/schemas/OrdningBase"
          },
          {
            "$ref": "#/components/schemas/OrdningUtvidet"
          },
          {
            "$ref": "#/components/schemas/Publisering"
          },
          {
            "type": "object",
            "properties": {
              "opprettet": {
                "type": "string",
                "format": "date-time",
                "example": "2025-08-27T15:45:30Z"
              },
              "endret": {
                "type": "string",
                "format": "date-time",
                "example": "2025-08-27T15:45:30Z"
              }
            }
          }
        ]
      },
      "OrdningElement": {
        "type": "object",
        "readOnly": true,
        "required": [
          "tilskuddsordningId",
          "ordningId",
          "tittel",
          "kortBeskrivelse",
          "status",
          "naering",
          "regionsnivaa",
          "region",
          "soknadsfrist",
          "rolle"
        ],
        "allOf": [
          {
            "$ref": "#/components/schemas/OrdningId"
          },
          {
            "$ref": "#/components/schemas/OrdningBase"
          }
        ]
      },
      "SokEtterOrdningResponse": {
        "type": "object",
        "readOnly": true,
        "required": [
          "ordninger"
        ],
        "properties": {
          "ordninger": {
            "type": "array",
            "maxItems": 1000,
            "items": {
              "$ref": "#/components/schemas/OrdningElement"
            }
          },
          "sidenummer": {
            "type": "integer"
          },
          "ordningerPrSide": {
            "type": "integer"
          },
          "totaltAntallSider": {
            "type": "integer"
          },
          "totaltAntallOrdninger": {
            "type": "integer"
          }
        }
      },
      "RegistrerOrdningRequest": {
        "type": "object",
        "writeOnly": true,
        "required": [
          "tittel",
          "kortBeskrivelse",
          "status",
          "naering",
          "regionsnivaa",
          "region",
          "soknadsfrist",
          "rolle",
          "kontaktperson"
        ],
        "allOf": [
          {
            "$ref": "#/components/schemas/OrdningBase"
          },
          {
            "$ref": "#/components/schemas/OrdningUtvidet"
          },
          {
            "$ref": "#/components/schemas/Publisering"
          }
        ]
      },
      "Tekst": {
        "type": "object",
        "required": [
          "tekst",
          "spraak"
        ],
        "properties": {
          "tekst": {
            "type": "string",
            "maxLength": 3000
          },
          "spraak": {
            "type": "string",
            "enum": [
              "NN",
              "NB",
              "SE",
              "EN"
            ],
            "example": "NB"
          }
        }
      },
      "Soknadsfrist": {
        "type": "object",
        "required": [
          "tilDato"
        ],
        "properties": {
          "fraDato": {
            "type": "string",
            "format": "date",
            "example": "2025-01-01"
          },
          "tilDato": {
            "type": "string",
            "format": "date",
            "example": "2025-01-01"
          }
        }
      },
      "Publisering": {
        "type": "object",
        "required": [
          "publiseringsdato"
        ],
        "properties": {
          "publiseringsdato": {
            "type": "string",
            "format": "date-time",
            "example": "2025-08-27T15:45:30Z"
          },
          "avpubliseringsdato": {
            "type": "string",
            "format": "date-time",
            "example": "2025-08-27T18:45:30Z"
          }
        }
      },
      "Rolleinnehaver": {
        "type": "object",
        "required": [
          "organisasjonsnummer"
        ],
        "properties": {
          "organisasjonsnummer": {
            "type": "string"
          },
          "navn": {
            "type": "string",
            "readOnly": true
          }
        }
      },
      "Rolle": {
        "type": "object",
        "required": [
          "type",
          "rolleinnehaver"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "rolleinnehaver": {
            "$ref": "#/components/schemas/Rolleinnehaver"
          }
        }
      },
      "Regionsnivaa": {
        "type": "string",
        "enum": [
          "ALLE",
          "ALLE_UTENOM_SVALBARD",
          "SPESIFIKT_ANGITT"
        ],
        "example": "ALLE"
      },
      "Kontaktperson": {
        "type": "object",
        "required": [
          "navn",
          "epost"
        ],
        "properties": {
          "navn": {
            "type": "string"
          },
          "stilling": {
            "type": "string"
          },
          "epost": {
            "type": "string",
            "pattern": "^[\\w\\-\\.]+@([\\w-]+\\.)+[\\w-]{2,}$",
            "example": "name@example.com"
          },
          "telefon": {
            "type": "string",
            "pattern": "(0047|\\+47)?\\d{8}"
          }
        }
      },
      "ErrorMessage": {
        "type": "object",
        "description": "Feilmelding fra Fiks-plattformen",
        "externalDocs": {
          "description": "Beskrivelse av feilmeldinger",
          "url": "https://ks-no.github.io/fiks-plattform/integrasjoner/#feilmeldinger"
        },
        "properties": {
          "timestamp": {
            "type": "integer",
            "format": "int64"
          },
          "status": {
            "type": "integer",
            "format": "int32"
          },
          "error": {
            "type": "string"
          },
          "errorId": {
            "type": "string",
            "format": "uuid"
          },
          "path": {
            "type": "string"
          },
          "originalPath": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "errorCode": {
            "type": "string"
          },
          "errorJson": {
            "type": "string"
          }
        },
        "example": {
          "message": "Mangler tilgang",
          "errorId": "ee2ed64d-de8b-45f9-b9c6-3363d662d93b",
          "status": 403
        }
      }
    }
  }
}
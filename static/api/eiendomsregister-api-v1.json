{
  "openapi": "3.0.3",
  "info": {
    "title": "KS FIKS: Eiendomsregister service",
    "description": "Eiendomsregister service",
    "contact": {
      "name": "Fiks brukerstøtte",
      "url": "https://ksdigital.no/om-oss/kontakt-oss",
      "email": "fiks@ksdigital.no"
    },
    "version": "v1"
  },
  "servers": [
    {
      "url": "https://api.fiks.ks.no",
      "description": "KS Fiks API host"
    },
    {
      "url": "https://api.fiks.test.ks.no",
      "description": "KS Fiks TEST API host"
    }
  ],
  "tags": [
    {
      "name": "Eiendomsregister",
      "description": "API for oppslag i eiendomsregisteret"
    }
  ],
  "paths": {
    "/eiendomsregister/api/v1/adresser": {
      "get": {
        "tags": [
          "Eiendomsregister"
        ],
        "description": "Hent adresser for en matrikkelenhet",
        "operationId": "hentAdresser",
        "parameters": [
          {
            "name": "kommunenummer",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "gaardsnummer",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "bruksnummer",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "seksjonsnummer",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "festenummer",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Matrikkelenhet med adresser",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MatrikkelenhetAPIModel"
                }
              }
            }
          },
          "400": {
            "description": "Ugyldig matrikkelnummer",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://developers.fiks.ks.no/api/fiks-common.json#/components/schemas/ErrorMessage"
                }
              }
            }
          },
          "403": {
            "description": "Ikke tilgang",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://developers.fiks.ks.no/api/fiks-common.json#/components/schemas/ErrorMessage"
                }
              }
            }
          },
          "404": {
            "description": "Matrikkelenhet ikke funnet",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://developers.fiks.ks.no/api/fiks-common.json#/components/schemas/ErrorMessage"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AdresseAPIModel": {
        "type": "object",
        "properties": {
          "adressenavn": {
            "type": "string"
          },
          "adressekode": {
            "type": "integer",
            "format": "int32"
          },
          "kommunenummer": {
            "type": "string"
          },
          "nummer": {
            "type": "integer",
            "format": "int32"
          },
          "bokstav": {
            "type": "string"
          }
        },
        "required": [
          "adressenavn",
          "adressekode",
          "kommunenummer"
        ]
      },
      "MatrikkelenhetAPIModel": {
        "type": "object",
        "properties": {
          "kommunenummer": {
            "type": "string"
          },
          "gaardsnummer": {
            "type": "integer",
            "format": "int32"
          },
          "bruksnummer": {
            "type": "integer",
            "format": "int32"
          },
          "festenummer": {
            "type": "integer",
            "format": "int32"
          },
          "seksjonsnummer": {
            "type": "integer",
            "format": "int32"
          },
          "erSeksjonert": {
            "type": "boolean"
          },
          "adresser": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AdresseAPIModel"
            }
          }
        },
        "required": [
          "kommunenummer",
          "gaardsnummer",
          "bruksnummer",
          "festenummer",
          "seksjonsnummer",
          "erSeksjonert",
          "adresser"
        ]
      }
    }
  }
}

{
  "openapi": "3.0.3",
  "info": {
    "title": "Felles modeller for systemkatalogen",
    "description": "Felles modeller for systemkatalogen",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "KontaktpunktType": {
        "type": "string",
        "enum": [
          "TELEFON",
          "EPOST",
          "ANNET"
        ]
      },
      "Adresse": {
        "type": "object",
        "properties": {
          "adresse": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "postnummer": {
            "type": "string"
          },
          "poststed": {
            "type": "string"
          },
          "land": {
            "type": "string"
          },
          "kommunenummer": {
            "type": "string"
          },
          "adresselinje1": {
            "type": "string"
          },
          "adresselinje2": {
            "type": "string"
          },
          "adresselinje3": {
            "type": "string"
          }
        }
      },
      "Enhet": {
        "type": "object",
        "properties": {
          "organisasjonsnummer": {
            "type": "string"
          },
          "navn": {
            "type": "string"
          },
          "postadresse": {
            "$ref": "#/components/schemas/Adresse"
          },
          "forretningsadresse": {
            "$ref": "#/components/schemas/Adresse"
          },
          "overordnetEnhet": {
            "type": "string"
          },
          "institusjonellSektorkode": {
            "$ref": "#/components/schemas/InstitusjonellSektorkode"
          },
          "fiksOrgType": {
            "type": "string"
          }
        }
      },
      "InstitusjonellSektorkode": {
        "type": "object",
        "properties": {
          "kode": {
            "type": "string"
          },
          "beskrivelse": {
            "type": "string"
          }
        }
      },
      "ProduktKategoriResponse": {
        "type": "object",
        "required": [
          "id",
          "navn",
          "beskrivelse"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "navn": {
            "type": "string",
            "maxLength": 255
          },
          "beskrivelse": {
            "type": "string",
            "maxLength": 1000
          }
        }
      },
      "KontaktpunktResponse": {
        "type": "object",
        "required": [
          "id",
          "produktId",
          "type",
          "navn",
          "beskrivelse",
          "verdi",
          "formaals"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "produktId": {
            "type": "string",
            "format": "uuid"
          },
          "type": {
            "$ref": "fiks-systemkatalog-felles-modeller-v1.json#/components/schemas/KontaktpunktType"
          },
          "navn": {
            "type": "string"
          },
          "beskrivelse": {
            "type": "string"
          },
          "verdi": {
            "type": "string",
            "description": "Kontaktverdi. For type TELEFON: 8 sifre eller +47 etterfulgt av 8 sifre. For type EPOST: gyldig e-postadresse."
          },
          "formaals": {
            "type": "array",
            "items": {
              "$ref": "fiks-systemkatalog-felles-modeller-v1.json#/components/schemas/KontaktpunktFormaalResponse"
            }
          }
        }
      },
      "KontaktpunktUpdateRequest": {
        "type": "object",
        "required": [
          "type",
          "navn",
          "beskrivelse",
          "verdi",
          "formaalIds"
        ],
        "properties": {
          "type": {
            "$ref": "fiks-systemkatalog-felles-modeller-v1.json#/components/schemas/KontaktpunktType"
          },
          "navn": {
            "type": "string",
            "maxLength": 255
          },
          "beskrivelse": {
            "type": "string",
            "maxLength": 1000
          },
          "verdi": {
            "type": "string",
            "maxLength": 255
          },
          "formaalIds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "format": "uuid"
            }
          }
        }
      },
      "LeverandoerRequest": {
        "type": "object",
        "required": [
          "organisasjonsnummer"
        ],
        "properties": {
          "organisasjonsnummer": {
            "type": "string",
            "pattern": "^\\d{9}$"
          }
        }
      },
      "ProduktRequest": {
        "type": "object",
        "required": [
          "navn",
          "beskrivelse",
          "produktKategoriId"
        ],
        "properties": {
          "navn": {
            "type": "string",
            "maxLength": 255
          },
          "beskrivelse": {
            "type": "string",
            "maxLength": 4000
          },
          "webadresse": {
            "type": "string",
            "format": "uri"
          },
          "kildeKode": {
            "type": "string",
            "format": "uri"
          },
          "produktKategoriId": {
            "type": "string",
            "format": "uuid"
          },
          "kontaktpunkter": {
            "type": "array",
            "description": "Valgfri liste med kontaktpunkter som opprettes sammen med produktet",
            "items": {
              "$ref": "#/components/schemas/KontaktpunktRequest"
            }
          },
          "tjenesteReferanser": {
            "type": "array",
            "description": "Valgfrie referanser til tjenester fra Avtale-API som knyttes til produktet",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "ProduktResponse": {
        "type": "object",
        "required": [
          "id",
          "leverandoerId",
          "navn",
          "beskrivelse",
          "produktKategori"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "leverandoerId": {
            "type": "string",
            "format": "uuid"
          },
          "navn": {
            "type": "string"
          },
          "beskrivelse": {
            "type": "string"
          },
          "webadresse": {
            "type": "string",
            "format": "uri"
          },
          "kildeKode": {
            "type": "string",
            "format": "uri"
          },
          "produktKategori": {
            "$ref": "fiks-systemkatalog-felles-modeller-v1.json#/components/schemas/ProduktKategoriResponse"
          },
          "kontaktpunkter": {
            "type": "array",
            "items": {
              "$ref": "fiks-systemkatalog-felles-modeller-v1.json#/components/schemas/KontaktpunktResponse"
            }
          },
          "tjenesteReferanser": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "KontaktpunktRequest": {
        "type": "object",
        "required": [
          "type",
          "navn",
          "beskrivelse",
          "verdi",
          "formaalIds"
        ],
        "properties": {
          "type": {
            "$ref": "fiks-systemkatalog-felles-modeller-v1.json#/components/schemas/KontaktpunktType"
          },
          "navn": {
            "type": "string",
            "maxLength": 255
          },
          "beskrivelse": {
            "type": "string",
            "maxLength": 1000
          },
          "verdi": {
            "type": "string",
            "maxLength": 255
          },
          "formaalIds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "format": "uuid"
            }
          }
        }
      },
      "KontaktpunktFormaalResponse": {
        "type": "object",
        "required": [
          "id",
          "kode",
          "navn"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "kode": {
            "type": "string",
            "maxLength": 50
          },
          "navn": {
            "type": "string",
            "maxLength": 255
          },
          "beskrivelse": {
            "type": "string",
            "maxLength": 1000
          }
        }
      }
    }
  }
}
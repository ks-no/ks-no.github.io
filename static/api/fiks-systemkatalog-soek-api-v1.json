{
  "openapi": "3.0.3",
  "info": {
    "title": "Systemkatalog Søk API",
    "description": "Søk-API for systemadministrasjon av leverandører, produkter og kontaktpunkter.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/systemkatalog/soek/api/v1",
      "description": "Søk API for systemkatalogen"
    }
  ],
  "tags": [
    {
      "name": "ProduktSoek"
    }
  ],
  "paths": {
    "/systemkatalog/soek/api/v1/produkter": {
      "get": {
        "tags": [
          "ProduktSoek"
        ],
        "parameters": [
          {
            "name": "tjenestekode",
            "in": "query",
            "description": "Tjenestekode for å søke etter produkter knyttet til denne tjenestekoden",
            "required": true,
            "example": "PROTOKOLL",
            "schema": {
              "type": "string"
            }
          }
        ],
        "summary": "Søk på produkter basert på søkeparametere",
        "operationId": "soekProdukter",
        "responses": {
          "200": {
            "description": "Liste over produkter",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ProduktMedLeverandoerResponse"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "LeverandoerSoekResponse": {
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "organisasjonsnummer": {
            "type": "string"
          },
          "navn": {
            "type": "string"
          },
          "postadresse": {
            "$ref": "fiks-systemkatalog-felles-modeller-v1.json#/components/schemas/Adresse"
          },
          "forretningsadresse": {
            "$ref": "fiks-systemkatalog-felles-modeller-v1.json#/components/schemas/Adresse"
          },
          "overordnetEnhet": {
            "type": "string"
          },
          "institusjonellSektorkode": {
            "$ref": "fiks-systemkatalog-felles-modeller-v1.json#/components/schemas/InstitusjonellSektorkode"
          },
          "fiksOrgType": {
            "type": "string"
          }
        }
      },
      "ProduktMedLeverandoerResponse": {
        "type": "object",
        "required": [
          "id",
          "leverandoer",
          "navn",
          "beskrivelse",
          "produktKategori"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "leverandoer": {
            "$ref": "#/components/schemas/LeverandoerSoekResponse"
          },
          "navn": {
            "type": "string"
          },
          "beskrivelse": {
            "type": "string"
          },
          "webadresse": {
            "type": "string",
            "format": "uri"
          },
          "kildeKode": {
            "type": "string",
            "format": "uri"
          },
          "produktKategori": {
            "$ref": "fiks-systemkatalog-felles-modeller-v1.json#/components/schemas/ProduktKategoriResponse"
          },
          "kontaktpunkter": {
            "type": "array",
            "items": {
              "$ref": "fiks-systemkatalog-felles-modeller-v1.json#/components/schemas/KontaktpunktResponse"
            }
          },
          "tjenesteReferanser": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
  "components": {
    "schemas": {
      "BopliktResponse": {
        "type": "object",
        "properties": {
          "harBoplikt": {
            "type": "string",
            "enum": [
              "JA",
              "NEI",
              "MULIGENS"
            ]
          },
          "bopliktForklaringResponse": {
            "type": "string",
            "enum": [
              "NEDSATT_KONSESJONSGRENSE_DEKKER_IKKE_HELE_EIENDOMMEN",
              "HVIS_IKKE_ARVER_FRA_SLEKTSKAP",
              "HVIS_EIENDOM_UNDER_OPPFOERING_OG_I_OMRAADE_REGULERT_TIL_BOLIGFORMAAL",
              "HVIS_UBEBYGD_EIENDOM_I_OMRAADE_REGULERT_TIL_BOLIGFORMAAL",
              "BRUKT_SOM_HELAARSBOLIG"
            ]
          }
        }
      },
      "EgenerklaeringPaakrevdOgBopliktResponse": {
        "type": "object",
        "properties": {
          "egenerklaeringPaakrevd": {
            "type": "boolean"
          },
          "boplikt": {
            "$ref": "#/components/schemas/BopliktResponse"
          }
        }
      },
      "PresjekkResponse": {
        "type": "string",
        "enum": [
          "KREVES_IKKE",
          "DEL_AV_STORRE_LANDBRUKSEIENDOM",
          "KREVER_EGENERKLARING"
        ]
      },
      "HovedsjekkResponse": {
        "type": "object",
        "properties": {
          "avklaringsId": {
            "type": "string",
            "format": "uuid"
          },
          "erverver": {
            "$ref": "#/components/schemas/ErververId"
          },
          "innsendtSkjemaStatus": {
            "$ref": "#/components/schemas/InnsendtSkjemaStatus"
          }
        }
      },
      "ErververId": {
        "type": "object",
        "properties": {
          "fodselsnummer": {
            "type": "string",
            "maxLength": 11,
            "minLength": 11
          },
          "organisasjonsnummer": {
            "type": "string",
            "maxLength": 9,
            "minLength": 9
          },
          "navn": {
            "type": "string"
          }
        },
        "required": [
          "fodselsnummer"
        ]
      },
      "ErververMedEierandel": {
        "type": "object",
        "description": "Erverver og eierskapsandel for en erverver i en egenerklæring",
        "properties": {
          "erverver": {
            "$ref": "#/components/schemas/Erverver"
          },
          "eiendommer": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EiendomMedEierandel"
            }
          }
        },
        "required": [
          "erverver",
          "eiendommer"
        ]
      },
      "EiendomMedEierandel": {
        "type": "object",
        "properties": {
          "eiendomsId": {
            "$ref": "#/components/schemas/EiendomsId"
          },
          "eierandel": {
            "$ref": "#/components/schemas/Eierandel"
          }
        },
        "required": [
          "eiendomsId"
        ]
      },
      "Erverver": {
        "type": "object",
        "required": [
          "erververId"
        ],
        "properties": {
          "erververId": {
            "$ref": "#/components/schemas/ErververId"
          },

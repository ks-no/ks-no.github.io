    "/selvdeklarering/api/v1/innleveringer/{id}/sporreskjema": {
      "get": {
        "summary": "Hent komplett sporreskjema for innlevering (composite)",
        "description": "Returnerer hele sporreskjemaet (alle pakker med spørsmål, svaralternativer og terskelregler) som innleveringen viser til, resolvert server-side fra sporsmalsbank. Erstatter behovet for at frontend kaller `/sporsmalsbank/pakker/{id}` per pakke. Arkitekturen krever at frontend ikke kommuniserer direkte mot sporsmalsbank — denne komposittendepointen er den autoriserte inngangen.",
        "operationId": "hentSporreskjema",
        "tags": [
          "Innlevering"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Komplett sporreskjema for innleveringen",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SporreskjemaForInnlevering"
                }
              }
            }
          },
          "404": {
            "description": "Innlevering eller tilknyttet selvdeklarering ikke funnet"
          },
          "409": {
            "description": "Selvdeklareringen er deaktivert"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
